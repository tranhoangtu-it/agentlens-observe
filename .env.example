# AgentLens Environment Variables
# Copy to .env and customize for your deployment

# Database — SQLite (default) or PostgreSQL
AGENTLENS_DB_PATH=./agentlens.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentlens

# Security — REQUIRED in production
AGENTLENS_JWT_SECRET=change-me-to-a-random-64-char-string

# CORS — comma-separated allowed origins
AGENTLENS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin seed credentials
AGENTLENS_ADMIN_EMAIL=admin@agentlens.local
AGENTLENS_ADMIN_PASSWORD=change-me-in-production
